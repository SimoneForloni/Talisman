<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1000.0" prefWidth="1920.0" stylesheets="@style/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <center>
      <HBox fx:id="mapContainer" styleClass="map-area" BorderPane.alignment="CENTER" />
   </center>
   <bottom>
      <HBox fx:id="logContainer" prefHeight="205.0" BorderPane.alignment="CENTER">
         <children>
            <AnchorPane fx:id="player1Stats" prefHeight="200.0" prefWidth="300.0" styleClass="stats-panel"> 
               </AnchorPane>
            <AnchorPane fx:id="centralLog" HBox.hgrow="ALWAYS" styleClass="log-panel" />
            <AnchorPane fx:id="player2Stats" prefHeight="200.0" prefWidth="300.0" styleClass="stats-panel"> 
               </AnchorPane>
         </children>
      </HBox>
   </bottom>
   <right>
      <ToolBar fx:id="menuToolbar" orientation="VERTICAL" prefWidth="150.0" BorderPane.alignment="CENTER">
          </ToolBar>
   </right>
</BorderPane>
